# ClipForge local development environment
# Copy to .env and fill in your real values. .env is gitignored.

# ─── Database ────────────────────────────────────────────────────────────
# Example for Neon (https://neon.tech):
# DATABASE_URL=postgresql://USER:PASS@HOST/DB?sslmode=require
# Example for local Postgres:
# DATABASE_URL=postgresql://clipforge:clipforge_dev@localhost:5432/clipforge
DATABASE_URL=

# ─── Redis ───────────────────────────────────────────────────────────────
# Local: redis://localhost:6379
# Cloud: redis://default:PASSWORD@HOST:PORT
REDIS_URL=redis://localhost:6379

# ─── API server ─────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
WEB_ORIGIN=http://localhost:5173
# IMPORTANT: generate a random 32+ char secret for production
JWT_SECRET=dev_secret_change_in_prod_clipforge_local_only

# ─── Local filesystem storage (no S3 needed) ────────────────────────────
# All generated clips, uploads, and merged videos are stored under this
# directory and served by the API at GET /api/v1/files/<key>.
# In Docker, set this to a mounted volume path (e.g. /data/clips).
# For local dev, the default is <cwd>/public/uploads.
CLIPS_DIR=

# ─── AI provider API keys ───────────────────────────────────────────────
# Google AI Studio (https://aistudio.google.com) — needs Veo access
GEMINI_API_KEY=

# MiniMax coding plan (https://platform.MiniMax.io) — sk-cp-…
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.io

# Provider model IDs (override without code change per PRD §19)
VEO_PRO_MODEL=veo-3.1-generate-preview
VEO_FLASH_MODEL=veo-3.1-fast-generate-preview
MINIMAX_MODEL=MiniMax-Hailuo-2.3

# OpenAI (only for T5.3 Whisper captions)
OPENAI_API_KEY=

# ─── First-run admin bootstrap ───────────────────────────────────────────
# These are only used if the `users` table is empty.
INITIAL_ADMIN_EMAIL=admin@clipforge.local
INITIAL_ADMIN_PASSWORD=Admin@123
INITIAL_ADMIN_DISPLAY=Admin

# ─── Worker concurrency ──────────────────────────────────────────────────
GENERATION_CONCURRENCY=2
MERGE_CONCURRENCY=1
CAPTIONS_CONCURRENCY=2

# ─── Logging ─────────────────────────────────────────────────────────────
LOG_LEVEL=info
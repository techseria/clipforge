{
  "name": "clipforge",
  "version": "0.1.0",
  "private": true,
  "description": "ClipForge — AI Video Generation Platform for Marketers",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n api,worker,web -c blue,green,magenta \"npm:dev --workspace=apps/api\" \"npm:dev --workspace=apps/worker\" \"npm:dev --workspace=apps/web\"",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "db:migrate": "npm run migrate --workspace=packages/db",
    "db:seed": "npm run seed --workspace=packages/db",
    "db:studio": "npm run studio --workspace=packages/db"
  },
  "devDependencies": {
    "concurrently": "^10.0.3",
    "typescript": "^7.0.2",
    "@types/node": "^26.1.1"
  },
  "engines": {
    "node": ">=20.10.0",
    "pnpm": ">=8.15.0"
  }
}
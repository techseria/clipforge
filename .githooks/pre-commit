#!/usr/bin/env bash
# gitleaks pre-commit hook
# Install: cp .githooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
# Or just rely on `git config core.hooksPath .githooks`

set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
GITLEAKS_BIN="${GITLEAKS_BIN:-/home/techseria/.local/bin/gitleaks}"
CONFIG="${REPO_ROOT}/.gitleaks.toml"

if [[ ! -x "$GITLEAKS_BIN" ]]; then
  echo "pre-commit: gitleaks not found at $GITLEAKS_BIN — install it or set GITLEAKS_BIN" >&2
  echo "          skipping secret scan (NOT recommended)" >&2
  exit 0
fi

# Scan only the staged changes (fast, runs on every commit).
"$GITLEAKS_BIN" protect --staged --redact --config="$CONFIG" --verbose